{
  "name": "grocery-server",
  "version": "1.0.0",
  "description": "Fastify Backend for Grocery POS",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "create-admin": "ts-node src/scripts/create-admin.ts",
    "seed": "ts-node src/scripts/seed-data.ts",
    "backup": "ts-node src/scripts/manage-backups.ts",
    "archive": "ts-node src/scripts/archive-data.ts"
  },
  "keywords": [
    "pos",
    "grocery",
    "inventory",
    "retail",
    "management",
    "fastify",
    "sqlite"
  ],
  "author": "Ameen Al-Sanabani",
  "license": "PolyForm-Noncommercial-1.0.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.0",
    "@fastify/multipart": "^8.3.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/uuid": "^10.0.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "cross-env": "^10.1.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.26.1",
    "fastify-type-provider-zod": "^1.1.9",
    "sqlite3": "^5.1.7",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.20",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  }
}